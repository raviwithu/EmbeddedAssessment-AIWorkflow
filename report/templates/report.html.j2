<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Assessment Report — {{ r.target_name }}</title>
<style>
  body { font-family: sans-serif; margin: 2rem; color: #222; }
  h1 { border-bottom: 2px solid #333; padding-bottom: .5rem; }
  h2 { margin-top: 2rem; color: #444; }
  table { border-collapse: collapse; width: 100%; margin-bottom: 1.5rem; }
  th, td { border: 1px solid #ccc; padding: .4rem .6rem; text-align: left; }
  th { background: #f5f5f5; }
  .pass { color: #2a7; } .fail { color: #c33; } .warn { color: #c90; } .info { color: #36a; }
  .meta { color: #666; font-size: .9rem; }
</style>
</head>
<body>
<h1>Embedded Assessment Report</h1>
<p class="meta">Target: <strong>{{ r.target_name }}</strong> | Platform: {{ r.platform }} | {{ r.timestamp.strftime('%Y-%m-%d %H:%M:%S UTC') }}</p>

<h2>System Information</h2>
<table>
  <tr><th>Hostname</th><td>{{ r.system_info.hostname }}</td></tr>
  <tr><th>Kernel</th><td>{{ r.system_info.kernel }}</td></tr>
  <tr><th>Architecture</th><td>{{ r.system_info.architecture }}</td></tr>
  <tr><th>OS Release</th><td>{{ r.system_info.os_release }}</td></tr>
  <tr><th>Uptime</th><td>{{ r.system_info.uptime }}</td></tr>
</table>

{% if r.processes %}
<h2>Processes ({{ r.processes | length }})</h2>
<table>
  <tr><th>PID</th><th>User</th><th>CPU%</th><th>MEM%</th><th>State</th><th>Command</th></tr>
  {% for p in r.processes %}
  <tr><td>{{ p.pid }}</td><td>{{ p.user }}</td><td>{{ p.cpu_percent }}</td><td>{{ p.mem_percent }}</td><td>{{ p.state }}</td><td>{{ p.command }}</td></tr>
  {% endfor %}
</table>
{% endif %}

{% if r.services %}
<h2>Services ({{ r.services | length }})</h2>
<table>
  <tr><th>Name</th><th>State</th><th>Enabled</th></tr>
  {% for s in r.services %}
  <tr><td>{{ s.name }}</td><td>{{ s.state }}</td><td>{{ s.enabled }}</td></tr>
  {% endfor %}
</table>
{% endif %}

{% if r.open_ports %}
<h2>Open Ports ({{ r.open_ports | length }})</h2>
<table>
  <tr><th>Protocol</th><th>Port</th><th>Address</th><th>Process</th></tr>
  {% for p in r.open_ports %}
  <tr><td>{{ p.protocol }}</td><td>{{ p.port }}</td><td>{{ p.address }}</td><td>{{ p.process }}</td></tr>
  {% endfor %}
</table>
{% endif %}

{% if r.hardening %}
<h2>Hardening Checks ({{ r.hardening | length }})</h2>
<table>
  <tr><th>ID</th><th>Category</th><th>Description</th><th>Status</th><th>Detail</th></tr>
  {% set safe_statuses = {'pass': 'pass', 'fail': 'fail', 'warn': 'warn', 'info': 'info'} %}
  {% for h in r.hardening %}
  <tr><td>{{ h.check_id }}</td><td>{{ h.category }}</td><td>{{ h.description }}</td><td class="{{ safe_statuses.get(h.status, '') }}">{{ h.status | upper }}</td><td>{{ h.detail }}</td></tr>
  {% endfor %}
</table>
{% endif %}

{% if r.hardware_interfaces %}
<h2>Hardware Interfaces ({{ r.hardware_interfaces | length }})</h2>
<table>
  <tr><th>Type</th><th>Device</th><th>Description</th><th>Accessible</th></tr>
  {% for hw in r.hardware_interfaces %}
  <tr><td>{{ hw.type | upper }}</td><td>{{ hw.device_path }}</td><td>{{ hw.description }}</td><td>{{ hw.accessible }}</td></tr>
  {% endfor %}
</table>
{% endif %}

{% if r.errors %}
<h2>Errors</h2>
<ul>
  {% for e in r.errors %}
  <li>{{ e }}</li>
  {% endfor %}
</ul>
{% endif %}

<hr>
<p class="meta">Generated by Embedded Assessment Platform</p>
</body>
</html>
