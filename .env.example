# n8n credentials
N8N_USER=admin
N8N_PASSWORD=changeme

# Collector service
LOG_LEVEL=INFO
COLLECTOR_CONFIG=/app/config/config.yaml

# SSH target credentials (used as defaults when not provided in request body)
SSH_HOST=192.168.1.100
SSH_PORT=22
SSH_USERNAME=root
SSH_AUTH=key
SSH_KEY_PATH=~/.ssh/id_ed25519
SSH_PASSWORD=
SSH_TIMEOUT=10
SSH_CMD_TIMEOUT=30
